   "source": [
    "def average(array):\n",
    "    array = set(array)\n",
    "\n",
    "    l = len(array)\n",
    "    s = sum(array)\n",
    "\n",
    "    avg = round((s / l),3)\n",
    "    return avg\n",
    "\n",
    "average([161 ,182, 161, 154, 176, 170, 167, 171, 170, 174])\n"
   ]
  }
